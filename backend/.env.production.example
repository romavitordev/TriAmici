# ───────────────────────────────────────────────────────────
# Backend — Produção (VPS Ubuntu 24 / PM2)
# Copie para backend/.env e preencha com os valores reais.
# ───────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# Origens permitidas (separe por vírgula). Use o domínio real com https.
CORS_ORIGIN=https://triamici.com.br,https://www.triamici.com.br

# Banco de dados (PostgreSQL local no VPS)
# Opcao A: variaveis individuais
DB_SERVER=localhost
DB_PORT=5432
DB_NAME=triamici_db
DB_USER=triamici
DB_PASSWORD=SENHA_FORTE_AQUI
# Opcao B (tem prioridade): string unica
# DATABASE_URL=postgres://triamici:SENHA_FORTE_AQUI@localhost:5432/triamici_db

# E-mail (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_DESTINO=escola@triamici.com.br
# Apos validar o dominio no Resend, troque para: Tri Amici Site <noreply@triamici.com.br>
EMAIL_FROM=Tri Amici Site <onboarding@resend.dev>
