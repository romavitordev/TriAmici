PORT=3001
CORS_ORIGIN=http://localhost:3000
NODE_ENV=development

# Banco de dados (PostgreSQL)
# Opcao A: variaveis individuais (abaixo)
# Opcao B: string unica (tem prioridade) -> DATABASE_URL=postgres://user:pass@host:5432/db
DB_SERVER=localhost
DB_PORT=5432
DB_NAME=triamici_db
DB_USER=postgres
DB_PASSWORD=sua_senha_aqui

# E-mail (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_DESTINO=escola@triamici.com.br

# Remetente do Resend (use onboarding@resend.dev ate validar o dominio)
EMAIL_FROM=Tri Amici Site <onboarding@resend.dev>

# Admin (painel de pré-inscrições — sem banco de usuários)
ADMIN_USER=triamici_admin
ADMIN_PASSWORD=senha_forte_aqui
# Gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=string_aleatoria_de_64_caracteres_aqui
